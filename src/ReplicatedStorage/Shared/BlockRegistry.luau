function BlockRegistry.get(blockType: number): BlockDef?
	return defs[blockType]
end

function BlockRegistry.getAll(): { [number]: BlockDef }
	return defs
end

function BlockRegistry.isSolid(blockType: number): boolean
	return blockType ~= BlockType.Air and blockType ~= BlockType.Water
end

function BlockRegistry.isTransparent(blockType: number): boolean
	return blockType == BlockType.Air or blockType == BlockType.Water
end

return BlockRegistry
